# ============================================================================
# ook — example environment configuration
#
# Copy to `.env.local` and fill in. Both files are gitignored. None of the
# variables below are required for local dev — sensible fallbacks kick in.
# ============================================================================

# Absolute path to the books vault (the directory that contains per-book
# subdirectories and `_meta/`). For local dev, point this at your Obsidian
# books folder. When unset, the code looks for `<cwd>/.vault`, which the
# production prebuild script populates by cloning `vhata/books`.
BOOKS_DIR=/absolute/path/to/books

# Public canonical URL of the deployed site. Used to build absolute links in
# the Atom + JSON feeds and any other surface that needs a non-relative URL.
# Falls back to the production URL when unset; override locally for staging or
# preview deploys.
# OOK_SITE_URL=https://b-ook.vercel.app

# (Production-only) SSH private key used by `scripts/fetch-vault.mjs` at build
# time on Vercel to clone the private `vhata/books` repo. Configured in the
# Vercel dashboard, not in this file. Local dev no-ops if unset.
# BOOKS_DEPLOY_KEY=...

# ============================================================================
# MCP write surface (deferred, see docs/proposals/mcp-write-surface.md)
# ============================================================================
# All variables below gate the optional /admin + /api/mcp routes. The public
# render layer doesn't touch any of them; you can leave them all unset.

# Storage backend. Provision Upstash Redis through the Vercel Marketplace and
# the integration auto-injects these. When unset, the code falls back to an
# in-process MemoryStore (lost on every restart) — fine for local dev, but
# refused in production unless OOK_ALLOW_MEMORY_STORE=1.
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# OOK_ALLOW_MEMORY_STORE=1

# WebAuthn auth surface.
#   - SESSION_SECRET: 32+ byte random secret used to sign session cookies.
#     Generate with `openssl rand -hex 32`. REQUIRED to operate /admin.
#   - RP_ID: WebAuthn Relying Party ID, defaults to the SITE_URL host.
#     Must be the bare domain — no scheme, no port. Override only if the
#     site is reachable on multiple origins.
#   - RP_NAME: human-readable name shown in the OS dialog.
#   - EXPECTED_ORIGIN: full origin (scheme + host[:port]) used in
#     verification. Defaults to OOK_SITE_URL.
#   - OWNER_USERNAME: opaque single-user identifier. Defaults to "owner".
#   - SESSION_TTL_SECONDS: cookie lifetime. Defaults to 30 days.
# OOK_AUTH_SESSION_SECRET=...
# OOK_AUTH_RP_ID=b-ook.vercel.app
# OOK_AUTH_RP_NAME=ook
# OOK_AUTH_EXPECTED_ORIGIN=https://b-ook.vercel.app
# OOK_AUTH_OWNER_USERNAME=owner
# OOK_AUTH_SESSION_TTL_SECONDS=2592000

# GitHub fine-grained PAT used by `commit_patch` to push to vhata/books.
# Scope: contents read/write + metadata read on vhata/books only. No org
# permissions, no other repos.
# GITHUB_BOOKS_PAT=github_pat_...
# GITHUB_BOOKS_REPO=vhata/books
# GITHUB_BOOKS_BRANCH=main

# Anthropic API for the /admin orchestration. Set a monthly cap in the
# console before going live — the /admin loop is a closed system but
# runaway protection is cheap insurance.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# Shared secret that GitHub's webhook on vhata/books signs requests with
# (X-Hub-Signature-256). When set, /api/webhooks/books/reindex verifies
# the signature and triggers a fresh `reindex()` so the MCP store stays
# in sync with the vault without manual admin-button clicks. Generate
# with `openssl rand -hex 32` and paste the same value into the GitHub
# webhook's "Secret" field.
# OOK_BOOKS_WEBHOOK_SECRET=...

# Fine-grained PAT (actions:write on the ook repo) used by the books-repo
# webhook handler to fire a `repository_dispatch` of type `vault-hygiene`
# after every successful reindex, kicking off
# `.github/workflows/vault-hygiene.yml`. When unset the dispatch is
# skipped silently and reindex still completes — the workflow can also
# be triggered manually from the Actions tab.
# GITHUB_OOK_DISPATCH_PAT=github_pat_...
# OOK_DISPATCH_REPO=vhata/ook
