# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local data (optional symlink to the books vault for dev — BOOKS_DIR can also be absolute)
/books

# vault checkout populated by scripts/fetch-vault.mjs in production builds
/.vault

# editor / OS
*.swp
.idea/
.vscode/

# claude worktrees
.claude/worktrees/

# typescript build/test artefacts (beyond Next.js defaults already listed above)
dist/
.vite/
.turbo/
test-results/
playwright-report/
*.log
